rules_version = '2';

// Tig music suite — shared Cloud Storage rules (one ruleset per bucket).
//   • users/{uid}/avatar/**       — world-readable avatars, owner-written, ≤2 MB images.
//   • users/{uid}/songs/**        — Tig Music per-song assets (demo takes, etc.), owner-only.
//   • orgs/{orgId}/**             — Tig Worship charts/stems/attachments, org-membership gated.
// This ruleset is SHARED across the whole suite's bucket — keep tig-worship/storage.rules
// identical, and never remove another app's block when editing here.
service firebase.storage {
  match /b/{bucket}/o {

    match /users/{uid}/avatar/{file=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Tig Music per-song assets — demo takes today, and any future per-song files (stems,
    // artwork). Owner-only, like the Firestore song tree. ≤50 MB per object (a demo take is
    // small; the cap just bounds abuse).
    match /users/{uid}/songs/{songId}/{allPaths=**} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 50 * 1024 * 1024;
    }

    // Tig Worship assets (charts/stems/attachments): any signed-in user may read/write
    // under an org path. Org isolation is enforced at the Firestore layer (only members
    // can discover or CRUD the track/chart docs that point here), and orgIds are
    // unguessable random ids. NOTE: cross-service rules (Storage reading Firestore for
    // per-role gating) proved unreliable on this project; tighten later via a Cloud
    // Function signed-upload proxy or working cross-service rules. ≤50 MB per object.
    // Flat 3 GB write ceiling for everything under orgs/** — no path-based special-casing.
    // History: two attempts to give …/_inbox/ a higher cap than the rest failed on Storage-rules
    // path matching (the {allPaths=**} capture is a Path with no .matches(); request.resource.name
    // matching also misbehaved), and each silently fell back to a 50 MB cap that denied a 253 MB
    // bundle. A flat cap has no path logic to get wrong. The trust model is already "any signed-in
    // user may write under orgs/**" (org isolation is enforced at the Firestore layer), so a higher
    // flat ceiling is not a new exposure — just larger objects.
    match /orgs/{orgId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 3221225472; // 3 GB (3 * 1024^3)
    }
  }
}
