{
  "hosting": {
    "target": "music",
    "public": "dist/tig-music/browser",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [{ "source": "**", "destination": "/index.html" }],
    "headers": [
      {
        "source": "**",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "**/*.@(js|css|woff2|woff|ttf|png|jpg|jpeg|gif|svg|ico|webp)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      }
    ]
  },
  "functions": {
    "source": "functions",
    "codebase": "tig-music",
    "runtime": "nodejs22"
  }
}
