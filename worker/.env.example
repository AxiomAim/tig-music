# Tig Music audio worker — copy to .env and fill in. NEVER commit the real .env or the key file.

# --- Firebase (service account with Firestore + Storage admin) ---
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json
FIREBASE_PROJECT_ID=tig-powell
FIREBASE_STORAGE_BUCKET=tig-powell.firebasestorage.app
JOBS_COLLECTION=songImports

# --- Compute (auto-detected: cuda > mps > cpu). Uncomment to force. ---
# DEVICE=mps
# DEMUCS_DEVICE=cpu          # force Demucs to CPU if MPS throws an unsupported-op error
DEMUCS_MODEL=htdemucs        # htdemucs (fast) | htdemucs_ft (slower, a bit better)

# --- Whisper (faster-whisper). GPU box: large-v3/float16. Mac mini: medium/int8 on cpu. ---
# WHISPER_MODEL=large-v3
# WHISPER_DEVICE=cuda
# WHISPER_COMPUTE=float16

# --- Optional LLM title suggestion from lyrics (OpenAI-compatible; e.g. local Ollama). ---
# Leave LLM_BASE_URL empty to skip and fall back to the filename.
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=gemma3:1b
# LLM_API_KEY=

# --- Runtime ---
POLL_INTERVAL_SEC=5
WORK_DIR=/tmp/tig-music-worker
